# Local dev config. Copy to .env (gitignored); vite.config.ts loads it onto process.env for the dev
# server and for `CF=1 vite build`. Everything here is OPTIONAL — `pnpm dev` works with no .env.
#
# Deploying to Cloudflare Workers? You do NOT need the R2_* credentials below — Workers use a native
# R2 bucket binding (no keys). See docs/DEPLOY_CLOUDFLARE.md for the full deploy guide.

# ── Image uploads — Cloudflare R2 over the S3 API ────────────────────────────────────────────────
# Only for storing uploads in R2 from a NON-Workers host (incl. local dev testing). When ALL five are
# set, server/upload.ts uploads to R2 via the S3 API; otherwise it writes to .uploads/ (dev fallback).
# To get these:
#   1. Create an R2 bucket in the Cloudflare dashboard (or: wrangler r2 bucket create strut-uploads).
#   2. Enable public access (r2.dev) or attach a custom domain — that URL is R2_PUBLIC_BASE_URL.
#   3. Create an R2 API token (S3 Auth) → gives the Access Key ID + Secret Access Key.
#   4. Account ID is shown on the R2 overview page.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public base URL for the bucket (no trailing slash), e.g.
#   https://pub-xxxxxxxx.r2.dev   or   https://assets.yourdomain.com
R2_PUBLIC_BASE_URL=

# ── Runnable artifacts — sandbox origin (OPTIONAL) ───────────────────────────────────────────────
# Runnable "artifact" blocks run untrusted author code in a sandboxed iframe. The iframe is opaque-origin
# (sandbox="allow-scripts", no allow-same-origin), so this is defense-in-depth: serve the built artifacts
# from a SEPARATE origin than the app for real cross-origin isolation + HTTP CSP headers. Set this to that
# origin (no trailing slash), e.g. https://sandbox.strut.io — add it as a second custom domain on the same
# Worker so /a/<key> answers there. If UNSET, artifacts are served same-origin at /a/<key> (still sandboxed,
# just without the second boundary). Leave empty for local dev.
ARTIFACT_ORIGIN=

# ── Auth (Better-Auth) ───────────────────────────────────────────────────────────────────────────
# Strut is guest-first: the first visit mints a server-signed ANONYMOUS session (the rindle principal),
# so there's no sign-in wall and the SSR loader can seed first paint. Under `pnpm dev` (Node, no D1),
# getAuth() falls back to a local better-sqlite3 auth DB (./auth.db, gitignored, auto-migrated from
# migrations-d1/) — so the guest flow works with NO cloud setup. Only these two are REQUIRED locally:
#   BETTER_AUTH_SECRET  — any 32+ byte secret (openssl rand -base64 32).
#   BETTER_AUTH_URL     — the dev origin; must match how you open the app (default http://localhost:3000).
# BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
# BETTER_AUTH_URL=http://localhost:3000
# STRUT_AUTH_DB=auth.db                 # optional: local dev auth DB path
# Optional — only needed to test PROMOTION (guest → real account). Create OAuth apps with callback
# http://localhost:3000/api/auth/callback/{github,google}. On Cloudflare these are wrangler secrets.
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# Host-split support (OPTIONAL) — only for the official/commercial deploy, where the app runs on a
# subdomain (app.strut.io) and the marketing page on the apex (strut.io). Both unset = single-host, the
# default self-host behavior. See docs/COMMERCIAL_OVERLAY.md.
# AUTH_TRUSTED_ORIGINS=https://strut.io      # extra comma-separated trusted origins beyond BETTER_AUTH_URL
# AUTH_COOKIE_DOMAIN=.strut.io               # parent domain to share the session across subdomains

# ── Bring-your-own-LLM — OpenRouter credential sealing (OPTIONAL) ─────────────────────────────────
# Only needed to test "Connect your model" (a BYO OpenRouter key) locally. MODEL_CRED_KEY seals each
# user's API key at rest with AES-GCM in the auth DB (server/modelCred.ts); without it, CONNECTING a model
# fails with a clear error, but everything else — including the app-paid Workers AI features — works fine.
# Must decode to 32 bytes. Generate with: openssl rand -base64 32. On Cloudflare it's a wrangler secret.
# MODEL_CRED_KEY=

# ── App-paid AI model — Anthropic Claude Haiku (OPTIONAL) ────────────────────────────────────────
# The default backend for the app-paid ✨ features (Arrange, Generate, Chat, Edit). When set, those
# features run on Claude Haiku (server/llm.ts) instead of Cloudflare Workers AI (Llama) — a small, genuinely
# good model as the "free taste". WITHOUT it, the features fall back to Workers AI, so nothing breaks; the
# same daily quota (server/quota.ts) meters either backend. A user who connects their own OpenRouter key
# still overrides this per request (they pay). On Cloudflare: wrangler secret put ANTHROPIC_API_KEY.
# ANTHROPIC_API_KEY=

# ── Pointing at a remote rindled daemon (optional) ───────────────────────────────────────────────
# Defaults target a local daemon (http://127.0.0.1:7600 / ws://127.0.0.1:7601). Override to point dev
# at a hosted daemon. On Cloudflare these are set as wrangler `vars` instead (see the deploy doc).
#   RINDLE_DAEMON_URL / RINDLE_DAEMON_WS are RUNTIME config: the server reads the http URL, and the
#   browser fetches the ws URL from /api/rindle/config at boot — so no rebuild to change hosts.
# RINDLE_DAEMON_URL=https://your-daemon-host.example.com
# RINDLE_DAEMON_WS=wss://your-daemon-host.example.com
# RINDLE_DAEMON_TOKEN=your-daemon-token
# VITE_RINDLE_WS=wss://your-daemon-host.example.com   # optional build-time override (runtime wins)

# ── Analytics (Umami) — OPTIONAL, OFF by default ─────────────────────────────────────────────────
# Privacy-first, cookieless product analytics. Both are BUILD-TIME vars (VITE_-prefixed → inlined by
# `vite build`), NOT wrangler runtime vars — set them in the environment that runs the build/deploy.
# Leave them UNSET (the default) and Strut loads no script and collects nothing — a clean clone phones
# home to no one. To enable: create a website in Umami Cloud (https://umami.is) or your own instance,
# then set both. Self-hosters point VITE_UMAMI_SRC at their own Umami. See src/lib/analytics.ts.
# VITE_UMAMI_SRC=https://cloud.umami.is/script.js       # the tracker script URL from your Umami install
# VITE_UMAMI_ID=00000000-0000-0000-0000-000000000000    # the website id Umami assigns
