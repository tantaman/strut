{
  "name": "strut",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "daemon": "rindle up --migrate --gen shared/schema.ts --watch",
    "setup": "rindle migrate apply && rindle schema gen --out shared/schema.ts",
    "dev": "concurrently -k -n daemon,web -c blue,green \"rindle up --migrate --gen shared/schema.ts --watch\" \"pnpm dev:web\"",
    "dev:web": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check ."
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@rindle/api-server": "^0.2.0",
    "@rindle/client": "^0.2.0",
    "@rindle/daemon-client": "^0.2.0",
    "@rindle/optimistic": "^0.2.0",
    "@rindle/react": "^0.2.0",
    "@rindle/wasm": "^0.2.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "dompurify": "^3.4.11",
    "fractional-indexing": "^3.3.0",
    "lucide-react": "^0.545.0",
    "marked": "^18.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@rindle/cli": "^0.2.0",
    "@rindle/react-devtools": "^0.2.0",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
