{
  // Cloudflare Workers config for the Strut web app (TanStack Start). See docs/DEPLOY_CLOUDFLARE.md.
  //
  // This deploys the SSR app + same-origin API/upload routes to Workers. The `rindled` daemon
  // (SQLite + live-query WebSocket) CANNOT run on Workers — host it separately and point
  // RINDLE_DAEMON_URL / RINDLE_DAEMON_WS at it. See the deploy doc for the daemon hosting plan.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "strut",
  // Pinned to the installed workerd (1.20260701) so local tooling doesn't warn; bump freely.
  "compatibility_date": "2026-07-01",
  // nodejs_compat: upload.ts / rindle-api.ts use node builtins (crypto, fs fallback) and process.env.
  // With this flag, process.env is populated from `vars` + secrets below — so RINDLE_DAEMON_URL etc.
  // keep working unchanged. R2 bucket bindings are the exception: read via `cloudflare:workers`.
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "observability": {
    "enabled": true,
  },

  // Native R2 storage. Uploaded images go straight to this bucket via the binding — no S3
  // credentials needed on Workers. server/upload.ts reads it as env.STRUT_UPLOADS.
  // Create the bucket first:  wrangler r2 bucket create strut-uploads
  "r2_buckets": [
    {
      "binding": "STRUT_UPLOADS",
      "bucket_name": "strut-uploads",
    },
  ],

  // Non-secret config, surfaced on process.env at runtime (nodejs_compat).
  //   RINDLE_DAEMON_URL  — https URL of your hosted rindled control plane (used by the Worker/server).
  //   RINDLE_DAEMON_WS   — wss URL of the daemon's live-query WebSocket. Served to the browser at
  //                        runtime via /api/rindle/config, so changing it is a var edit + redeploy —
  //                        no client rebuild. (Leave empty to fall back to the local dev default.)
  //   R2_PUBLIC_BASE_URL — OPTIONAL. Public bucket/custom-domain base (e.g. https://pub-xxx.r2.dev).
  //                        If set, uploads return that CDN URL directly. If empty, images are served
  //                        back through the Worker from the bucket (private bucket is fine).
  "vars": {
    "RINDLE_DAEMON_URL": "https://rindle-a218b5eae4fd49bc.fly.dev:8443",
    "RINDLE_DAEMON_WS": "wss://rindle-a218b5eae4fd49bc.fly.dev",
    "R2_PUBLIC_BASE_URL": "",
  },

  // Secrets are NOT stored here. Set them with wrangler:
  //   wrangler secret put RINDLE_DAEMON_TOKEN
  // (R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY are only needed for the S3 fallback path, not on Workers.)
}
